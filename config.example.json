    "ALPACA_API_SECRET": "YOUR_ALPACA_SECRET_HERE",
    "ALPACA_ENDPOINT": "https://data.alpaca.markets/v2",

    "UPDATE_URL": "",

    "TICKER_GROUPS": [
        ["AAPL", "MSFT", "TSLA"],
        ["NVDA", "GOOGL", "AMZN"]
