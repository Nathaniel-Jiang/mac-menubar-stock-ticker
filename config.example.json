{
    "_comment": "Copy this file to ~/.xbar_stock_config.json and edit. Run `chmod 600` after.",

    "THRESHOLDS": [5, 10, 15, 20, 25],

    "COLOR_UP": "#228B22",
    "COLOR_DOWN": "#DC143C",
    "COLOR_NORMAL": "#FFFFFF",

    "ENABLE_SOUND_ALERT": true,
    "ENABLE_NOTIFICATIONS": true,
    "STOCK_ALERT_COOLDOWN_MINUTES": 5,
